          <button class="btn-waze"
                  onclick="window.open('https://waze.com/ul?q=Margot+Loyola+Palacios+4366+Temuco+Chile&navigate=yes','_blank')">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C7 2 3 6 3 11c0 3.5 2 6.5 5 8l1 3h6l1-3c3-1.5 5-4.5 5-8 0-5-4-9-9-9z"/>
              <circle cx="9"  cy="10" r="1.2" fill="currentColor" stroke="none"/>
              <circle cx="15" cy="10" r="1.2" fill="currentColor" stroke="none"/>
              <path d="M9 14c1 1.5 5 1.5 6 0"/>
            </svg>
            Waze
          </button>
        </div>

      </div>
    </div>

    <!-- Info cards -->
    <div class="anim-in" style="padding:14px 18px 0;display:grid;grid-template-columns:1fr 1fr;gap:10px;animation-delay:0.38s;">
      <div class="mini-card">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="#c2607e" stroke-width="1.6">
          <rect x="3" y="11" width="18" height="10" rx="2"/>
          <path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
        <div>
          <div style="font-family:'Quicksand',sans-serif;font-size:9px;font-weight:700;
                      letter-spacing:1.5px;text-transform:uppercase;color:var(--rose-deep);">Estacionamiento</div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:15px;
                      color:var(--ink);font-style:italic;margin-top:2px;">Pasaje amplio y tranquilo</div>
        </div>
      </div>
      <div class="mini-card">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="#c2607e" stroke-width="1.6">
          <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
        </svg>
        <div>
          <div style="font-family:'Quicksand',sans-serif;font-size:9px;font-weight:700;
                      letter-spacing:1.5px;text-transform:uppercase;color:var(--rose-deep);">Recepción</div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:15px;
                      color:var(--ink);font-style:italic;margin-top:2px;">Desde 14:30 PM</div>
        </div>
      </div>
    </div>

    <!-- Quote -->
    <div class="anim-in" style="padding:14px 18px 0;animation-delay:0.52s;">
      <div class="quote-strip">"Sigue las nubes rositas — te guiarán a nuestra fiesta."</div>
    </div>

    <!-- Nota dulce -->
    <div class="anim-in" style="padding:12px 18px 0;animation-delay:0.66s;">
      <div class="nota-estelar">
        <div style="display:flex;align-items:flex-start;gap:14px;">

          <!-- Ícono polerón/chaqueta -->
          <div class="nota-icon">
            <svg width="28" height="28" viewBox="0 0 34 34" fill="none"
                 xmlns="http://www.w3.org/2000/svg">
              <path d="M12 7 L6 13 L3 12 L3 20 L7 20 L7 29 L27 29 L27 20 L31 20 L31 12 L28 13 L22 7"
                    fill="rgba(244,139,164,0.2)"
                    stroke="#c2607e" stroke-width="1.6"
                    stroke-linejoin="round" stroke-linecap="round"/>
              <path d="M12 7 Q17 12 22 7"
                    fill="none" stroke="#c2607e" stroke-width="1.6"
                    stroke-linecap="round"/>
              <path d="M7 26 L27 26"
                    stroke="#c2607e" stroke-width="1.2"
                    stroke-linecap="round" opacity="0.55"/>
              <path d="M3 17 L7 17"
                    stroke="#c2607e" stroke-width="1.2"
                    stroke-linecap="round" opacity="0.55"/>
              <path d="M27 17 L31 17"
                    stroke="#c2607e" stroke-width="1.2"
                    stroke-linecap="round" opacity="0.55"/>
              <path d="M17 12 L17 29"
                    stroke="#c2607e" stroke-width="0.9"
                    stroke-linecap="round" opacity="0.3"
                    stroke-dasharray="2 3"/>
            </svg>
          </div>

          <div style="flex:1;">
            <div class="nota-header">✦ Nota dulce</div>
            <p class="nota-text">
              La celebración será en casa; el espacio es reducido pero el corazón es grande.
              Tendremos habilitado el espacio abierto, así que les recomendamos traer
              un <strong style="color:var(--rose-deep);font-weight:700;">polerón o chaqueta abrigadora</strong>
              para disfrutar cómodamente.
            </p>
          </div>

        </div>
      </div>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 3 · REGALOS
  ════════════════════════════════════════════════════════ -->
  <section id="sec-gifts" class="section" data-screen-label="Regalos">

    <div class="anim-in" style="padding:68px 20px 0;text-align:center;margin-bottom:4px;animation-delay:0.08s;">
      <div class="eyebrow">· Sugerencias para Emi ·</div>
      <div class="screen-title">Regalos</div>
    </div>

    <!-- Gift box hero -->
    <div class="anim-in" style="position:relative;text-align:center;padding:6px 0 0;animation-delay:0.18s;">
      <img src="assets/cloud_pink.png" alt=""
           style="position:absolute;top:-8px;left:-20px;width:172px;opacity:0.72;pointer-events:none;
                  animation:cloudDriftL 17s ease-in-out 1s infinite;">
      <img src="assets/cloud_orange.png" alt=""
           style="position:absolute;top:4px;right:-20px;width:160px;opacity:0.68;pointer-events:none;
                  animation:cloudDriftR 19s ease-in-out 3s infinite;">
      <img src="assets/gift_box.png" alt=""
           style="position:relative;width:128px;
                  filter:drop-shadow(0 12px 18px rgba(160,78,107,0.28));
                  animation:bob 4s ease-in-out infinite;">
      <span class="f-star" style="font-size:16px;top:20px;left:18%;animation-delay:0s;">✦</span>
      <span class="f-star" style="font-size:12px;top:40px;right:22%;animation-delay:1s;">✧</span>
    </div>

    <!-- Intro -->
    <p class="anim-in" style="text-align:center;padding:8px 28px 14px;animation-delay:0.3s;
              font-family:'Cormorant Garamond',serif;font-style:italic;
              font-size:16px;color:#ffffff;line-height:1.55;margin:0;
              text-shadow:0 2px 6px rgba(77,54,45,0.45),0 4px 12px rgba(77,54,45,0.25);">
      Lo más importante es tu compañía.<br>
      Si deseas regalarle algo, aquí algunas ideas:
    </p>

    <!-- Clothing sizes card -->
    <div class="anim-in" style="padding:0 18px;animation-delay:0.42s;">
      <div class="paper-card" style="padding:18px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div class="cat-icon" style="background:radial-gradient(circle at 30% 30%,#f3c8d2,#d9b8df);">
            <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
              <path d="M10 6L6 10v4l4-1v13h12V13l4 1v-4l-4-4-3 2a3 3 0 01-6 0L10 6z"
                    fill="#fff9f6" stroke="#a24e6b" stroke-width="1.4" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:22px;
                        color:var(--ink);font-weight:500;line-height:1;">Ropita</div>
            <div style="font-family:'Quicksand',sans-serif;font-size:11px;font-weight:600;
                        letter-spacing:1.5px;text-transform:uppercase;color:var(--rose-deep);margin-top:4px;">
              Tallas que le quedan
            </div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:12px;">
          <div class="sz-badge hi">
            <div class="sz-num" style="font-size:22px;">9-12</div>
            <div class="sz-sub">meses</div>
          </div>
          <div class="sz-badge hi">
            <div class="sz-num" style="font-size:22px;">12-18</div>
            <div class="sz-sub">meses</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Diapers card -->
    <div class="anim-in" style="padding:12px 18px 0;animation-delay:0.56s;">
      <div class="paper-card" style="padding:18px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div class="cat-icon" style="background:radial-gradient(circle at 30% 30%,#f3c8d2,#d9b8df);">
            <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
              <path d="M5 11C9 9 14 8 16 8s7 1 11 3c1 7-2 13-11 13S4 18 5 11z"
                    fill="#fff9f6" stroke="#a24e6b" stroke-width="1.4"/>
              <path d="M9 12c4-1 10-1 14 0" stroke="#a24e6b" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:22px;
                        color:var(--ink);font-weight:500;line-height:1;">Pañalitos</div>
            <div style="font-family:'Quicksand',sans-serif;font-size:9px;font-weight:600;
                        letter-spacing:1.5px;text-transform:uppercase;color:var(--rose-deep);
                        opacity:0.85;margin-top:5px;">Sugerencia de tallas</div>
            <div style="display:flex;gap:8px;margin-top:6px;">
              <span style="font-family:'Quicksand',sans-serif;font-size:15px;font-weight:700;
                           letter-spacing:2px;color:var(--ink);
                           background:rgba(255,255,255,0.6);
                           border:1.5px solid rgba(194,96,126,0.5);
                           border-radius:999px;padding:4px 14px;
                           box-shadow:inset 0 1px 3px rgba(255,255,255,0.4),0 1px 4px rgba(160,78,107,0.12);">G</span>
              <span style="font-family:'Quicksand',sans-serif;font-size:15px;font-weight:700;
                           letter-spacing:2px;color:var(--ink);
                           background:rgba(255,255,255,0.6);
                           border:1.5px solid rgba(194,96,126,0.5);
                           border-radius:999px;padding:4px 14px;
                           box-shadow:inset 0 1px 3px rgba(255,255,255,0.4),0 1px 4px rgba(160,78,107,0.12);">XG</span>
            </div>
          </div>
        </div>
        <div style="margin-top:12px;">
          <div style="font-family:'Quicksand',sans-serif;font-size:11px;font-weight:600;
                      letter-spacing:1px;text-transform:uppercase;color:var(--rose-deep);
                      margin-bottom:8px;">Marcas que usa</div>
          <div style="display:flex;gap:10px;">
            <a href="https://pilucho.cl/" target="_blank" rel="noopener"
               style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;
                      padding:11px 8px;border-radius:12px;text-decoration:none;
                      background:rgba(255,255,255,0.55);border:1.5px solid rgba(194,96,126,0.4);">
              <span style="font-family:'Cormorant Garamond',serif;font-size:18px;
                           color:var(--ink);font-weight:600;">Pilucho</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                   stroke="#c2607e" stroke-width="2.2" stroke-linecap="round">
                <path d="M7 17 17 7M17 7H9M17 7v8"/>
              </svg>
            </a>
            <a href="https://www.windel.cl" target="_blank" rel="noopener"
               style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;
                      padding:11px 8px;border-radius:12px;text-decoration:none;
                      background:rgba(255,255,255,0.55);border:1.5px solid rgba(194,96,126,0.4);">
              <span style="font-family:'Cormorant Garamond',serif;font-size:18px;
                           color:var(--ink);font-weight:600;">Windel</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                   stroke="#c2607e" stroke-width="2.2" stroke-linecap="round">
                <path d="M7 17 17 7M17 7H9M17 7v8"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Wishlist link + Figaro decorativo -->
    <div class="anim-in" style="padding:12px 18px 0;animation-delay:0.68s;
                                position:relative;overflow:visible;">
      <a href="#" class="wishlist-link">
        <div>
          <div style="font-family:'Quicksand',sans-serif;font-size:9px;font-weight:700;
                      letter-spacing:2px;text-transform:uppercase;color:var(--rose-deep);">Lista de deseos (No es obligatorio)</div>
          <div style="font-family:'Cormorant Garamond',serif;font-style:italic;
                      font-size:15px;color:var(--ink);margin-top:2px;line-height:1.4;">
            Juguetitos de niña más grande<br>y libros ilustrados
          </div>
        </div>
      </a>

      <!-- Figaro: asoma del borde inferior-derecho de la tarjeta -->
      <img src="assets/figaro_disney.png" alt="Gatito Figaro"
           style="position:absolute;bottom:-58px;right:-6px;width:108px;
                  filter:drop-shadow(0 8px 18px rgba(160,78,107,0.28));
                  animation:float 3.8s ease-in-out 0.5s infinite;
                  pointer-events:none;z-index:3;">
    </div>

    <!-- Espacio visual para Figaro + margen sobre la barra de nav -->
    <div style="height:80px;" aria-hidden="true"></div>

  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 4 · RSVP
  ════════════════════════════════════════════════════════ -->
  <section id="sec-rsvp" class="section" data-screen-label="Confirmar">

    <div class="anim-in" style="padding:68px 20px 0;text-align:center;margin-bottom:4px;animation-delay:0.08s;">
      <div class="eyebrow">· Confirma tu asistencia ·</div>
      <div class="screen-title" style="font-size:clamp(32px,8.5vw,48px);line-height:1.05;">
        ¿Nos acompañas<br>a celebrar?
      </div>
    </div>

    <div class="anim-in" style="padding:6px 16px 0;position:relative;animation-delay:0.22s;">
      <span class="f-star" style="font-size:14px;top:-4px;left:20px;animation-delay:0s;">✦</span>
      <span class="f-star" style="font-size:12px;top:20px;right:28px;animation-delay:1.4s;">✧</span>

      <div class="forms-paper">
        <iframe
          src="https://docs.google.com/forms/d/e/1FAIpQLSfn8ph5dmOCU3CJcWUJ0ceBQVYWgbBUmUD-Q1QS9ma3bO9xlQ/viewform?embedded=true"
          width="100%"
          height="1200"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          style="display:block;"
          title="Confirmación de asistencia a la fiesta de Emi">
          Cargando formulario…
        </iframe>
      </div>
    </div>

    <!-- Contact + WhatsApp -->
    <div class="anim-in" style="padding:18px 18px 0;animation-delay:0.42s;">
      <p style="font-family:'Quicksand',sans-serif;font-weight:700;
                font-size:18px;line-height:1.55;color:#ffffff;
                text-align:center;margin:0 0 16px;
                text-shadow:0 2px 6px rgba(77,54,45,0.45),0 4px 12px rgba(77,54,45,0.25);">
        ¿Tienes alguna duda sobre la fiesta?<br>
        Únete a nuestro grupo de coordinación<br>
        para estar al tanto de todo.
      </p>
      <a class="btn-whatsapp"
         href="https://chat.whatsapp.com/HY9JSBXhU04B0ftRWLFoEn"
         target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.531 5.845L.057 23.428l5.726-1.502A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.808 9.808 0 01-5.001-1.368l-.358-.214-3.72.975.992-3.634-.234-.374A9.818 9.818 0 012.182 12C2.182 6.576 6.576 2.182 12 2.182S21.818 6.576 21.818 12 17.424 21.818 12 21.818z"/>
        </svg>
        Unirse al Grupo de WhatsApp
      </a>
    </div>

    <!-- Spacer: para que el nav nunca tape el botón de WhatsApp -->
    <div style="height:160px;" aria-hidden="true"></div>

  </section>

  <!-- ═══════════════════════════════════════════════════════
       BOTTOM NAV
  ════════════════════════════════════════════════════════ -->
  <nav id="bottom-nav" role="navigation" aria-label="Secciones">
    <button class="nav-btn active" data-sec="sec-hero" onclick="showSection('sec-hero')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="9.2" stroke="currentColor" stroke-width="1.6"/>
        <circle cx="12" cy="7.5" r="1.1" fill="currentColor"/>
        <path d="M12 11v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <span class="nav-lbl">Detalles</span>
    </button>
    <button class="nav-btn" data-sec="sec-map" onclick="showSection('sec-map')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <path d="M12 21.5s7-7 7-12.5a7 7 0 10-14 0c0 5.5 7 12.5 7 12.5z"
              stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        <circle cx="12" cy="9" r="2.4" fill="currentColor" fill-opacity="0.4"/>
      </svg>
      <span class="nav-lbl">Mapa</span>
    </button>
    <button class="nav-btn" data-sec="sec-gifts" onclick="showSection('sec-gifts')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <rect x="3.5" y="9.5" width="17" height="11" rx="1.5"
              stroke="currentColor" stroke-width="1.6"/>
        <path d="M3 9.5h18M12 9.5v11" stroke="currentColor" stroke-width="1.6"/>
        <path d="M12 9.5C9 9.5 7 8 7 6.2c0-1.2 1-2.2 2.2-2.2 1.7 0 2.8 1.5 2.8 5.5z
                 M12 9.5C15 9.5 17 8 17 6.2c0-1.2-1-2.2-2.2-2.2C13.1 4 12 5.5 12 9.5z"
              stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
      <span class="nav-lbl">Regalos</span>
    </button>
    <button class="nav-btn" data-sec="sec-rsvp" onclick="showSection('sec-rsvp')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="9.2" stroke="currentColor" stroke-width="1.6"/>
        <path d="M7.5 12.5l3 3 6-6.5" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="nav-lbl">Confirmar</span>
    </button>
  </nav>

  <!-- Botón mute flotante -->
  <button id="btn-mute" aria-label="Silenciar música" style="
    position:fixed;top:14px;right:14px;z-index:90;
    width:38px;height:38px;border-radius:50%;
    background:rgba(255,255,255,0.55);
    border:1px solid rgba(194,96,126,0.35);
    backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
    display:flex;align-items:center;justify-content:center;
    cursor:pointer;padding:0;color:var(--rose-deep);
    transition:background 0.2s,opacity 0.2s;
    opacity:0;pointer-events:none;">
    <svg id="ico-sound" width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
    </svg>
    <svg id="ico-muted" width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
         style="display:none;">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <line x1="23" y1="9" x2="17" y2="15"/>
      <line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
  </button>

  <!-- Opening loader — intro de globos flotando -->
  <div id="opening" aria-hidden="true">
    <div id="launch-scene">
      <!-- Nubes suaves alrededor de los globos -->
      <img id="smoke-l" src="assets/cloud_pink.png" alt="">
      <img id="smoke-r" src="assets/cloud_orange.png" alt="">
      <!-- Wrapper recibe el ascenso; img mantiene su balanceo -->
      <div id="rocket-wrapper">
        <img id="launch-rocket" src="assets/pink_ballons.png" alt="Globos flotando">
      </div>
    </div>
    <!-- Subtítulos: fijos al fondo -->
    <div id="launch-text"></div>
  </div>

</div><!-- #app -->

<!-- Audio ambiental — fuera de #app para persistir entre secciones -->
<audio id="bg-audio" src="assets/Under_a_Velvet_Sky.mp3" preload="auto"></audio>

<script>
/* ── Config ──────────────────────────────────────────────────── */
const PARTY_DATE = '2026-05-09T14:30:00';

/* ── Campo de destellos (determinista) ───────────────────────── */
(function() {
  const container = document.getElementById('stars');
  let seed = 7;
  const rand = () => { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };
  for (let i = 0; i < 60; i++) {
    const el = document.createElement('div');
    const x = rand() * 100, y = rand() * 100;
    const s = (1.0 + rand() * 2.0).toFixed(1);
    const o = (0.25 + rand() * 0.5).toFixed(2);
    const d = (rand() * 4).toFixed(1);
    const dur = 3 + (i % 3);
    // Alterna entre destellos blancos y rosados para un brillo de acuarela
    const col = (i % 3 === 0) ? '255,255,255' : '226,139,164';
    el.style.cssText = `position:absolute;left:${x.toFixed(1)}%;top:${y.toFixed(1)}%;`
      + `width:${s}px;height:${s}px;border-radius:50%;background:rgba(${col},${o});`
      + `box-shadow:0 0 ${(s*2.4).toFixed(1)}px rgba(${col},${(o*0.8).toFixed(2)});`
      + `animation:twinkle ${dur}s ease-in-out ${d}s infinite;`;
    container.appendChild(el);
  }
})();

/* ── Live countdown ──────────────────────────────────────────── */
(function() {
  const target = new Date(PARTY_DATE).getTime();
  const els = ['days','hours','mins','secs'].map(id => document.getElementById('cd-' + id));
  const pad = n => String(n).padStart(2, '0');
  const tick = () => {
    let diff = Math.max(0, target - Date.now());
    const d = Math.floor(diff / 86400000); diff -= d * 86400000;
    const h = Math.floor(diff / 3600000);  diff -= h * 3600000;
    const m = Math.floor(diff / 60000);    diff -= m * 60000;
    const s = Math.floor(diff / 1000);
    [d, h, m, s].forEach((v, i) => { els[i].textContent = pad(v); });
  };
  tick();
  setInterval(tick, 1000);
})();

/* ── Section navigation ──────────────────────────────────────── */
function showSection(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  const sec = document.getElementById(id);
  sec.classList.add('active');
  sec.scrollTop = 0;
  document.querySelector(`[data-sec="${id}"]`).classList.add('active');
}

/* ── Ambient audio + mute control ───────────────────────────── */
(function() {
  const audio  = document.getElementById('bg-audio');
  const btn    = document.getElementById('btn-mute');
  const icoOn  = document.getElementById('ico-sound');
  const icoOff = document.getElementById('ico-muted');
  const TARGET_VOL  = 0.4;
  const FADE_IN_MS  = 3000;
  const FADE_OUT_S  = 4;
  let muted = false, fadingOut = false;

  function doFadeIn() {
    fadingOut = false;
    audio.volume = 0;
    const steps = 60, delta = TARGET_VOL / steps, iv = FADE_IN_MS / steps;
    let s = 0;
    const t = setInterval(() => {
      if (fadingOut) return clearInterval(t);
      s++;
      audio.volume = Math.min(TARGET_VOL, delta * s);
      if (s >= steps) clearInterval(t);
    }, iv);
    btn.style.opacity = '1';
    btn.style.pointerEvents = 'auto';
  }

  audio.addEventListener('timeupdate', () => {
    if (!audio.duration || muted) return;
    const remaining = audio.duration - audio.currentTime;
    if (remaining <= FADE_OUT_S) {
      fadingOut = true;
      audio.volume = Math.max(0, TARGET_VOL * (remaining / FADE_OUT_S));
    }
  });
  audio.addEventListener('ended', () => {
    audio.currentTime = 0;
    audio.play().then(doFadeIn).catch(() => {});
  });

  audio.play().then(doFadeIn).catch(() => {
    const resume = () => { audio.play().then(doFadeIn).catch(() => {}); };
    document.addEventListener('click',      resume, { once: true });
    document.addEventListener('touchstart', resume, { once: true });
  });

  window._audioFadeIn = function() {};

  btn.addEventListener('click', () => {
    muted = !muted;
    audio.muted = muted;
    icoOn.style.display  = muted ? 'none' : '';
    icoOff.style.display = muted ? ''     : 'none';
    btn.style.background = muted
      ? 'rgba(255,255,255,0.3)'
      : 'rgba(255,255,255,0.55)';
  });
})();

/* ── Opening overlay — intro de globos flotando ──────────────── */
(function() {
  const el      = document.getElementById('opening');
  const wrapper = document.getElementById('rocket-wrapper');
  const smokeL  = document.getElementById('smoke-l');
  const smokeR  = document.getElementById('smoke-r');

  // Countdown: 4s + 0.4s delay = 4.4s. El ascenso arranca con buffer.
  setTimeout(() => {
    el.style.pointerEvents = 'none';
    window._audioFadeIn();

    // Globos: flotan suavemente hacia arriba (ease-in marcado)
    wrapper.style.animation = 'balloonRise 1.8s cubic-bezier(0.45,0,0.7,1) forwards';
    // Nubes: se desvanecen suavemente
    smokeL.style.animation = 'cloudFade 1.6s ease-out forwards';
    smokeR.style.animation = 'cloudFade 1.6s ease-out 0.1s forwards';
    // Tras el ascenso: fade del overlay
    setTimeout(() => {
      el.classList.add('out');
      setTimeout(() => el.remove(), 950);
    }, 1400);
  }, 4600);
})();

/* RSVP: gestionado por Google Forms (ver iframe en sec-rsvp) */
</script>

</body>
</html>
